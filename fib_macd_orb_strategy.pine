// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0
// Fib-MACD ORB Pullback Strategy [NSE]
// Based on backtested Fib-MACD strategy: OR sets direction → breakout → swing →
// Fibonacci retracement entry at 61.8% (or 38.2/50%) with MACD confirmation.
// Best results (Run 7): 30-min OR, 61.8% fib, histogram_rising MACD, 1.5R, 34 stocks.
//
// HOW TO USE:
//   1. Apply to NSE 1-min chart (required — OR logic is time-based from 9:15 IST)
//   2. Add a MACD indicator in a separate pane (12, 26, 9) to visualise MACD state
//   3. Adjust inputs to match your backtest params — defaults are the best-performing combo
//
// STRATEGY LOGIC (mirrors fib_macd_engine.py exactly):
//   Step 1  Build Opening Range during first N minutes (9:15–9:45 for 30-min OR)
//   Step 2  Wait for first price breakout above OR high (LONG) or below OR low (SHORT)
//   Step 3  Track post-breakout swing high/low — confirmed when price retraces 0.3% from peak
//   Step 4  Draw Fibonacci: OR_low → swing_high (LONG) or OR_high → swing_low (SHORT)
//   Step 5  Entry: price WICKS into fib level, then CLOSES back above (LONG) / below (SHORT) it
//           MACD (5-min) must confirm direction
//   Step 6  Stop-loss: just below 78.6% fib level (+ SL buffer)
//   Step 7  Target: entry ± risk × target_R
//   Step 8  Force-close at exit time (default 15:14)
//
// VISUAL STABILITY NOTE:
//   All drawing (lines, labels, boxes) happens exclusively in barstate.islast.
//   The state machine only updates data variables — no objects are created mid-bar.
//   This prevents any flickering or repositioning when scrolling or zooming the chart.

//@version=6
strategy(
  title                   = "Fib-MACD ORB Pullback [NSE]",
  shorttitle              = "FibORB",
  overlay                 = true,
  max_bars_back           = 5000,
  max_lines_count         = 500,
  max_labels_count        = 500,
  max_boxes_count         = 200,
  initial_capital         = 100000,
  default_qty_type        = strategy.fixed,
  default_qty_value       = 1,
  currency                = currency.INR,
  commission_type         = strategy.commission.percent,
  commission_value        = 0.03,
  slippage                = 2,
  process_orders_on_close = true
)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

string G_ORB  = "Opening Range"
string G_FIB  = "Fibonacci & Entry"
string G_MACD = "MACD Filter (5-min)"
string G_RISK = "Risk Management"
string G_TIME = "Session & Exit Time"
string G_VIS  = "Visuals"

i_or_min        = input.int   (30,    "OR Duration (min)",    options=[15, 30],                   group=G_ORB,
                                tooltip="15-min OR is faster but noisier. 30-min is best per backtest.")
i_max_wait      = input.int   (60,    "Max Wait Bars (swing)", minval=10, maxval=200,              group=G_ORB,
                                tooltip="Max 1-min bars after breakout to wait for swing confirmation.")

i_fib_entry     = input.float (0.618, "Fib Entry Level",      options=[0.382, 0.5, 0.618],        group=G_FIB,
                                tooltip="Retracement level to enter at. 61.8% is best per backtest.")
i_swing_confirm = input.float (0.3,   "Swing Confirm %",      minval=0.1, maxval=1.5, step=0.1,   group=G_FIB,
                                tooltip="% retrace from peak/trough to lock in swing high/low.") / 100
i_sl_buffer     = input.float (0.1,   "SL Buffer %",          minval=0.0, maxval=0.5, step=0.05,  group=G_FIB,
                                tooltip="Extra margin below 78.6% fib for stop-loss.") / 100
i_brk_type      = input.string("Immediate", "Breakout Type",  options=["Immediate", "Candle Close"], group=G_FIB)
i_direction     = input.string("Both", "Trade Direction",      options=["Long Only", "Short Only", "Both"], group=G_FIB)

i_macd_cond     = input.string("Histogram Rising", "MACD Condition",
                                options=["Histogram Positive", "Histogram Rising", "MACD Cross", "None"],
                                group=G_MACD,
                                tooltip="Filter applied to 5-min MACD at entry bar. 'Histogram Rising' is best per backtest.")
i_macd_fast     = input.int   (12, "Fast Length",  group=G_MACD)
i_macd_slow     = input.int   (26, "Slow Length",  group=G_MACD)
i_macd_sig      = input.int   (9,  "Signal Length",group=G_MACD)

i_target_r      = input.float (1.5,   "Target (R multiple)",  options=[1.5, 2.0, 2.5, 3.0],      group=G_RISK,
                                tooltip="Profit target as a multiple of risk. 1.5R is best per backtest.")
i_risk_inr      = input.float (1000,  "Max Risk per Trade ₹", minval=100, maxval=50000,            group=G_RISK,
                                tooltip="Qty = floor(risk / (entry − SL)). Capped by available capital.")

i_exit_h        = input.int   (15,  "Force Exit Hour",   minval=9, maxval=15, group=G_TIME)
i_exit_m        = input.int   (14,  "Force Exit Minute", minval=0, maxval=59, group=G_TIME)
i_tz            = input.string("Asia/Kolkata", "Chart Timezone", group=G_TIME,
                                tooltip="Set to Asia/Kolkata for NSE.")

i_show_or       = input.bool  (true,  "Show OR Box",       group=G_VIS, inline="v1")
i_show_fib      = input.bool  (true,  "Show Fib Levels",   group=G_VIS, inline="v1")
i_show_swing    = input.bool  (true,  "Show Swing Label",  group=G_VIS, inline="v1")
i_show_dash     = input.bool  (true,  "Show Dashboard",    group=G_VIS, inline="v1")
i_show_macd_bg  = input.bool  (true,  "MACD Background",   group=G_VIS, inline="v2")
i_show_trade_bg = input.bool  (true,  "Trade Background",  group=G_VIS, inline="v2")
i_c_long        = input.color (color.new(#00c176, 0),  "Long",      group=G_VIS, inline="cols")
i_c_short       = input.color (color.new(#f7525f, 0),  "Short",     group=G_VIS, inline="cols")
i_c_fib         = input.color (color.new(#f7931a, 0),  "Fib Level", group=G_VIS, inline="cols")
i_c_sl          = input.color (color.new(#f7525f, 0),  "SL",        group=G_VIS, inline="cols")
i_c_tp          = input.color (color.new(#00bcd4, 0),  "TP",        group=G_VIS, inline="cols")
i_c_or          = input.color (color.new(#2962ff, 85), "OR Box",    group=G_VIS, inline="cols")

// ═══════════════════════════════════════════════════════════════════════════════
// TIME HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

t_mins        = hour(time, i_tz) * 60 + minute(time, i_tz)

SESSION_START = 9 * 60 + 15
OR_END        = SESSION_START + i_or_min
EXIT_MINS     = i_exit_h * 60 + i_exit_m

in_or_window  = t_mins >= SESSION_START and t_mins < OR_END  and t_mins < EXIT_MINS
after_or      = t_mins >= OR_END         and t_mins < EXIT_MINS
is_exit_bar   = t_mins >= EXIT_MINS
is_session_bar= t_mins >= SESSION_START  and t_mins <= 15 * 60 + 30
is_new_session= session.isfirstbar and is_session_bar

// ═══════════════════════════════════════════════════════════════════════════════
// MACD — 5-min timeframe
// ═══════════════════════════════════════════════════════════════════════════════

// Named wrapper required in v6 for tuple-returning request.security()
_macd_vals() => ta.macd(close, i_macd_fast, i_macd_slow, i_macd_sig)

[m_macd, m_sig, m_hist] = request.security(
    syminfo.tickerid, "5", _macd_vals(), lookahead=barmerge.lookahead_off)

macd_long  = switch i_macd_cond
    "Histogram Positive" => m_hist > 0
    "Histogram Rising"   => m_hist > m_hist[1]
    "MACD Cross"         => m_macd > m_sig
    => true

macd_short = switch i_macd_cond
    "Histogram Positive" => m_hist < 0
    "Histogram Rising"   => m_hist < m_hist[1]
    "MACD Cross"         => m_macd < m_sig
    => true

// ═══════════════════════════════════════════════════════════════════════════════
// STATE MACHINE — data variables only, no drawing here
// ═══════════════════════════════════════════════════════════════════════════════

var string state          = "IDLE"

// Opening Range
var float  or_h           = na
var float  or_l           = na
var int    or_start_bar   = na
var int    or_end_bar     = na    // bar index of last OR candle

// Breakout
var string brk_dir        = na
var int    bars_in_swing  = 0
var float  running_extr   = na

// Swing
var float  swing_val      = na
var int    swing_conf_bar = na

// Fibonacci levels
var float  f0             = na
var float  f100           = na
var float  f382           = na
var float  f500           = na
var float  f618           = na
var float  f786           = na
var float  f_entry        = na
var float  f_sl           = na

// Entry / exit
var bool   touched        = false
var float  entry_px       = na
var float  sl_px          = na
var float  tp_px          = na
var int    entry_bar      = na
var bool   entry_fired    = false

// Dashboard counters
var int    d_total        = 0
var int    d_wins         = 0
var float  d_pnl          = 0.0

// Multi-session OR history (arrays store each completed day's OR data)
var int[]   ha_start = array.new_int()
var int[]   ha_end   = array.new_int()
var float[] ha_orh   = array.new_float()
var float[] ha_orl   = array.new_float()
var box[]   ha_boxes = array.new_box()

// Visual object handles — updated only in barstate.islast
var box    or_box         = na
var line   ln_or_h        = na
var line   ln_or_l        = na
var line   ln_f100        = na
var line   ln_f382        = na
var line   ln_f500        = na
var line   ln_f618        = na
var line   ln_f786        = na
var line   ln_f0          = na
var line   ln_entry_fib   = na
var line   ln_sl          = na
var line   ln_tp          = na
var label  lb_entry       = na
var label  lb_swing       = na
var label  lb_f100        = na
var label  lb_fentry      = na
var label  lb_f786        = na
var label  lb_f0          = na

// ═══════════════════════════════════════════════════════════════════════════════
// PER-BAR STATE MACHINE  (data only — zero drawing calls)
// ═══════════════════════════════════════════════════════════════════════════════

if barstate.isconfirmed

    // ── New session: reset all data ──────────────────────────────────────────
    if is_new_session
        strategy.close_all("New Session")
        state         := "BUILD_OR"
        or_h          := high
        or_l          := low
        or_start_bar  := bar_index
        or_end_bar    := na
        brk_dir       := na
        bars_in_swing := 0
        running_extr  := na
        swing_val     := na
        swing_conf_bar:= na
        f0            := na
        f100          := na
        f382          := na
        f500          := na
        f618          := na
        f786          := na
        f_entry       := na
        f_sl          := na
        touched       := false
        entry_px      := na
        sl_px         := na
        tp_px         := na
        entry_bar     := na
        entry_fired   := false

    // ── BUILD_OR ─────────────────────────────────────────────────────────────
    if state == "BUILD_OR"
        if in_or_window
            or_h := math.max(or_h, high)
            or_l := math.min(or_l, low)
        else if after_or
            or_end_bar := bar_index - 1
            state      := "WAIT_BREAKOUT"
            // Save completed OR so barstate.islast can draw all historical boxes
            array.push(ha_start, or_start_bar)
            array.push(ha_end,   or_end_bar)
            array.push(ha_orh,   or_h)
            array.push(ha_orl,   or_l)
            if array.size(ha_start) > 199
                array.shift(ha_start)
                array.shift(ha_end)
                array.shift(ha_orh)
                array.shift(ha_orl)

    // ── WAIT_BREAKOUT ────────────────────────────────────────────────────────
    if state == "WAIT_BREAKOUT" and not is_exit_bar
        bool allow_l = i_direction != "Short Only"
        bool allow_s = i_direction != "Long Only"
        bool brk_l   = i_brk_type == "Candle Close" ? close > or_h : high > or_h
        bool brk_s   = i_brk_type == "Candle Close" ? close < or_l : low  < or_l

        if allow_l and brk_l
            brk_dir       := "LONG"
            running_extr  := high
            bars_in_swing := 0
            state         := "TRACK_SWING"
        else if allow_s and brk_s
            brk_dir       := "SHORT"
            running_extr  := low
            bars_in_swing := 0
            state         := "TRACK_SWING"

    // ── TRACK_SWING ──────────────────────────────────────────────────────────
    if state == "TRACK_SWING" and not is_exit_bar
        bars_in_swing += 1

        if bars_in_swing > i_max_wait
            state := "DONE"

        else if brk_dir == "LONG"
            if high > running_extr
                running_extr := high
            if close < running_extr * (1 - i_swing_confirm)
                swing_val      := running_extr
                swing_conf_bar := bar_index
                float rng = swing_val - or_l
                if rng > 0
                    f0      := or_l
                    f100    := swing_val
                    f382    := swing_val - 0.382 * rng
                    f500    := swing_val - 0.500 * rng
                    f618    := swing_val - 0.618 * rng
                    f786    := swing_val - 0.786 * rng
                    f_entry := i_fib_entry == 0.382 ? f382 : i_fib_entry == 0.5 ? f500 : f618
                    f_sl    := f786 * (1 - i_sl_buffer)
                    state   := "WAIT_ENTRY"
                else
                    state   := "DONE"

        else  // SHORT
            if low < running_extr
                running_extr := low
            if close > running_extr * (1 + i_swing_confirm)
                swing_val      := running_extr
                swing_conf_bar := bar_index
                float rng = or_h - swing_val
                if rng > 0
                    f0      := or_h
                    f100    := swing_val
                    f382    := swing_val + 0.382 * rng
                    f500    := swing_val + 0.500 * rng
                    f618    := swing_val + 0.618 * rng
                    f786    := swing_val + 0.786 * rng
                    f_entry := i_fib_entry == 0.382 ? f382 : i_fib_entry == 0.5 ? f500 : f618
                    f_sl    := f786 * (1 + i_sl_buffer)
                    state   := "WAIT_ENTRY"
                else
                    state   := "DONE"

    // ── WAIT_ENTRY ───────────────────────────────────────────────────────────
    entry_fired := false
    if state == "WAIT_ENTRY" and not is_exit_bar
        if brk_dir == "LONG"
            if close <= f_sl
                state := "DONE"
            else
                if not touched and low <= f_entry
                    touched := true
                if touched and close > f_entry and macd_long
                    entry_px    := f_entry
                    sl_px       := f_sl
                    float risk  = math.abs(entry_px - sl_px)
                    tp_px       := entry_px + risk * i_target_r
                    entry_bar   := bar_index
                    entry_fired := true
                    state       := "IN_TRADE"
                    int qty     = risk > 0 ? math.max(1, int(i_risk_inr / risk)) : 1
                    strategy.entry("Long",  strategy.long,  qty=qty, comment="FibORB Long")
                    strategy.exit ("Long Exit",  "Long",  stop=sl_px, limit=tp_px)
        else  // SHORT
            if close >= f_sl
                state := "DONE"
            else
                if not touched and high >= f_entry
                    touched := true
                if touched and close < f_entry and macd_short
                    entry_px    := f_entry
                    sl_px       := f_sl
                    float risk  = math.abs(sl_px - entry_px)
                    tp_px       := entry_px - risk * i_target_r
                    entry_bar   := bar_index
                    entry_fired := true
                    state       := "IN_TRADE"
                    int qty     = risk > 0 ? math.max(1, int(i_risk_inr / risk)) : 1
                    strategy.entry("Short", strategy.short, qty=qty, comment="FibORB Short")
                    strategy.exit ("Short Exit", "Short", stop=sl_px, limit=tp_px)

    // ── Force exit ───────────────────────────────────────────────────────────
    if is_exit_bar and (state == "IN_TRADE" or state == "WAIT_ENTRY")
        strategy.close_all("Time Exit")
        state := "DONE"

    // ── Track closed trades ──────────────────────────────────────────────────
    if strategy.closedtrades > d_total
        d_total := strategy.closedtrades
        float last_pnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
        d_pnl += last_pnl
        if last_pnl >= 0
            d_wins += 1

// ═══════════════════════════════════════════════════════════════════════════════
// BACKGROUND HIGHLIGHTS  (per-bar, but these are native plots — always stable)
// ═══════════════════════════════════════════════════════════════════════════════

bgcolor(in_or_window ? color.new(#2962ff, 94) : na, title="OR Period")

macd_aligned_long  = state == "WAIT_ENTRY" and brk_dir == "LONG"  and macd_long
macd_aligned_short = state == "WAIT_ENTRY" and brk_dir == "SHORT" and macd_short
bgcolor(i_show_macd_bg and macd_aligned_long  ? color.new(i_c_long,  92) : na, title="MACD Long OK")
bgcolor(i_show_macd_bg and macd_aligned_short ? color.new(i_c_short, 92) : na, title="MACD Short OK")
bgcolor(i_show_trade_bg and state == "IN_TRADE" and brk_dir == "LONG"  ? color.new(i_c_long,  95) : na, title="In Long Trade")
bgcolor(i_show_trade_bg and state == "IN_TRADE" and brk_dir == "SHORT" ? color.new(i_c_short, 95) : na, title="In Short Trade")

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAL SHAPES  (native plots — always stable)
// ═══════════════════════════════════════════════════════════════════════════════

plotshape(entry_fired and brk_dir == "LONG",  "Buy Signal",
          shape.triangleup,   location.belowbar, color=i_c_long,  size=size.normal, text="BUY",  textcolor=color.white)
plotshape(entry_fired and brk_dir == "SHORT", "Sell Signal",
          shape.triangledown, location.abovebar, color=i_c_short, size=size.normal, text="SELL", textcolor=color.white)

// Data window plots
plot(not na(or_h) and state != "BUILD_OR" ? or_h : na, "OR High", color=color.new(#2962ff,60), display=display.data_window)
plot(not na(or_l) and state != "BUILD_OR" ? or_l : na, "OR Low",  color=color.new(#2962ff,60), display=display.data_window)
plot(not na(f_entry) and (state == "WAIT_ENTRY" or state == "IN_TRADE") ? f_entry : na, "Fib Entry", color=i_c_fib, display=display.data_window)
plot(not na(sl_px)   and state == "IN_TRADE" ? sl_px : na, "SL",     color=i_c_sl, display=display.data_window)
plot(not na(tp_px)   and state == "IN_TRADE" ? tp_px : na, "Target", color=i_c_tp, display=display.data_window)

// ═══════════════════════════════════════════════════════════════════════════════
// DRAWING — barstate.islast ONLY
// All line/label/box objects are created here so they are never recreated
// mid-session. Chart interactions (scroll, zoom, resize) do NOT trigger
// barstate.islast, so drawings remain completely stable.
// ═══════════════════════════════════════════════════════════════════════════════

if barstate.islast

    // ── Wipe all previous objects ────────────────────────────────────────────
    box.delete(or_box)
    for _b in ha_boxes
        box.delete(_b)
    array.clear(ha_boxes)
    line.delete(ln_or_h),   line.delete(ln_or_l)
    line.delete(ln_f100),   line.delete(ln_f382),  line.delete(ln_f500)
    line.delete(ln_f618),   line.delete(ln_f786),  line.delete(ln_f0)
    line.delete(ln_entry_fib)
    line.delete(ln_sl),     line.delete(ln_tp)
    label.delete(lb_entry), label.delete(lb_swing)
    label.delete(lb_f100),  label.delete(lb_fentry)
    label.delete(lb_f786),  label.delete(lb_f0)

    // ── OR boxes — all sessions ──────────────────────────────────────────────
    if i_show_or
        // Historical completed sessions
        for _i = 0 to array.size(ha_start) - 1
            array.push(ha_boxes, box.new(
                  array.get(ha_start, _i), array.get(ha_orh, _i),
                  array.get(ha_end,   _i), array.get(ha_orl, _i),
                  bgcolor=i_c_or, border_color=color.new(#2962ff, 40), border_width=1))
        // Current session's OR if still building (not yet in arrays)
        if not na(or_start_bar) and not na(or_h) and na(or_end_bar)
            or_box := box.new(or_start_bar, or_h, bar_index, or_l,
                              bgcolor=i_c_or, border_color=color.new(#2962ff, 40), border_width=1)

    // ── OR level dashed lines (breakout reference) ───────────────────────────
    if not na(or_end_bar) and not na(or_h)
        ln_or_h := line.new(or_end_bar, or_h, bar_index, or_h,
                            color=color.new(#2962ff, 50), width=1, style=line.style_dashed, extend=extend.right)
        ln_or_l := line.new(or_end_bar, or_l, bar_index, or_l,
                            color=color.new(#2962ff, 50), width=1, style=line.style_dashed, extend=extend.right)

    // ── Fibonacci levels ─────────────────────────────────────────────────────
    if i_show_fib and not na(swing_val) and not na(swing_conf_bar)
        bool  is_long   = brk_dir == "LONG"
        color anc_color = is_long ? i_c_long : i_c_short
        int   x1        = swing_conf_bar

        ln_f100      := line.new(x1, f100,    x1+1, f100,    color=color.new(anc_color, 55), width=1, style=line.style_dotted, extend=extend.right)
        ln_f382      := line.new(x1, f382,    x1+1, f382,    color=color.new(i_c_fib,   70), width=1, style=line.style_dotted, extend=extend.right)
        ln_f500      := line.new(x1, f500,    x1+1, f500,    color=color.new(i_c_fib,   70), width=1, style=line.style_dotted, extend=extend.right)
        ln_f618      := line.new(x1, f618,    x1+1, f618,    color=color.new(i_c_fib,   70), width=1, style=line.style_dotted, extend=extend.right)
        ln_f786      := line.new(x1, f786,    x1+1, f786,    color=color.new(i_c_sl,    50), width=1, style=line.style_dashed, extend=extend.right)
        ln_f0        := line.new(x1, f0,      x1+1, f0,      color=color.new(anc_color, 55), width=1, style=line.style_dotted, extend=extend.right)
        ln_entry_fib := line.new(x1, f_entry, x1+1, f_entry, color=i_c_fib,                 width=2, style=line.style_solid,  extend=extend.right)

        if i_show_swing
            lb_swing := label.new(swing_conf_bar, swing_val,
                                  (is_long ? "Swing High\n" : "Swing Low\n") + str.tostring(swing_val, format.mintick),
                                  color=color.new(anc_color, 60), textcolor=color.white,
                                  style=is_long ? label.style_label_down : label.style_label_up, size=size.small)

        lb_f100   := label.new(x1, f100,    " 100%  "  + str.tostring(f100,    format.mintick), color=color.new(color.white,100), textcolor=color.new(anc_color,40), style=label.style_label_right, size=size.tiny)
        lb_fentry := label.new(x1, f_entry, (is_long ? " ↑ Entry " : " ↓ Entry ") + str.tostring(i_fib_entry*100,"#.#") + "%  " + str.tostring(f_entry, format.mintick), color=color.new(color.white,100), textcolor=i_c_fib, style=label.style_label_right, size=size.small)
        lb_f786   := label.new(x1, f786,    " SL 78.6%  " + str.tostring(f786,  format.mintick), color=color.new(color.white,100), textcolor=color.new(i_c_sl,50),    style=label.style_label_right, size=size.tiny)
        lb_f0     := label.new(x1, f0,      " 0%  "    + str.tostring(f0,      format.mintick), color=color.new(color.white,100), textcolor=color.new(anc_color,40), style=label.style_label_right, size=size.tiny)

    // ── Entry label + SL/TP lines ─────────────────────────────────────────────
    if not na(entry_px) and not na(entry_bar)
        bool  is_long  = brk_dir == "LONG"
        float risk     = math.abs(entry_px - sl_px)
        float lbl_y    = is_long ? entry_px - risk * 0.3 : entry_px + risk * 0.3

        ln_sl    := line.new(entry_bar, sl_px, entry_bar+1, sl_px,
                             color=i_c_sl, width=2, style=line.style_dashed, extend=extend.right)
        ln_tp    := line.new(entry_bar, tp_px, entry_bar+1, tp_px,
                             color=i_c_tp, width=2, style=line.style_dashed, extend=extend.right)
        lb_entry := label.new(entry_bar, lbl_y,
                              (is_long ? "BUY" : "SELL") + " @ " + str.tostring(entry_px, format.mintick) +
                              "\nSL " + str.tostring(sl_px, format.mintick) +
                              "\nTP " + str.tostring(tp_px, format.mintick),
                              color=is_long ? i_c_long : i_c_short, textcolor=color.white,
                              style=is_long ? label.style_label_up : label.style_label_down, size=size.small)

    // ── Dashboard ────────────────────────────────────────────────────────────
    if i_show_dash
        var table dash = table.new(position.top_right, 2, 11,
                                   bgcolor=color.new(color.black,75),
                                   border_width=1, border_color=color.new(color.white,70),
                                   frame_width=2,  frame_color=color.new(color.white,50))

        float wr = d_total > 0 ? d_wins / d_total * 100 : 0.0

        table.merge_cells(dash, 0,0, 1,0)
        table.cell(dash,0,0, "Fib-MACD ORB  [NSE]",
                   text_color=color.white, bgcolor=color.new(#2962ff,50),
                   text_size=size.normal, text_halign=text.align_center)

        color s_col = switch state
            "IN_TRADE" => color.new(i_c_long,  40)
            "DONE"     => color.new(color.gray, 55)
            "BUILD_OR" => color.new(color.blue, 55)
            =>            color.new(color.black,60)
        table.cell(dash,0,1,"State",    text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,1, state,     text_color=color.white, bgcolor=s_col, text_size=size.small)

        color d_col = switch brk_dir
            "LONG"  => color.new(i_c_long,  40)
            "SHORT" => color.new(i_c_short, 40)
            =>         color.new(color.black,65)
        table.cell(dash,0,2,"Direction",text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,2, na(brk_dir) ? "—" : brk_dir, text_color=color.white, bgcolor=d_col, text_size=size.small)

        table.cell(dash,0,3,"Entry",    text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,3, na(entry_px) ? "—" : str.tostring(entry_px, format.mintick), text_color=color.white, bgcolor=color.new(color.black,60), text_size=size.small)

        table.cell(dash,0,4,"Stop Loss",text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,4, na(sl_px) ? "—" : str.tostring(sl_px, format.mintick), text_color=i_c_sl, bgcolor=color.new(color.black,60), text_size=size.small)

        table.cell(dash,0,5,"Target",   text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,5, na(tp_px) ? "—" : str.tostring(tp_px, format.mintick), text_color=i_c_tp, bgcolor=color.new(color.black,60), text_size=size.small)

        bool  macd_on = brk_dir == "LONG" ? macd_long : macd_short
        color macd_c  = macd_on ? color.new(i_c_long,40) : color.new(i_c_short,50)
        table.cell(dash,0,6,"MACD (5m)",text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,6, na(brk_dir) ? "—" : (macd_on ? "✓ Aligned" : "✗ Waiting"),
                   text_color=color.white, bgcolor=na(brk_dir) ? color.new(color.black,65) : macd_c, text_size=size.small)

        table.merge_cells(dash,0,7,1,7)
        table.cell(dash,0,7,"── Backtest Stats ──",
                   text_color=color.new(color.white,50), bgcolor=color.new(color.black,75),
                   text_size=size.tiny, text_halign=text.align_center)

        color wr_c = wr >= 50 ? color.new(i_c_long,40) : color.new(i_c_short,50)
        table.cell(dash,0,8,"Win Rate", text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,8, str.tostring(wr,"#.0") + "%  (" + str.tostring(d_wins) + "/" + str.tostring(d_total) + ")",
                   text_color=color.white, bgcolor=d_total>0 ? wr_c : color.new(color.black,65), text_size=size.small)

        color pnl_c = d_pnl >= 0 ? color.new(i_c_long,40) : color.new(i_c_short,50)
        table.cell(dash,0,9,"Net P&L ₹",text_color=color.new(color.white,30), bgcolor=color.new(color.black,70), text_size=size.small)
        table.cell(dash,1,9, (d_pnl>=0 ? "+" : "") + str.tostring(d_pnl,"#.0"),
                   text_color=color.white, bgcolor=d_total>0 ? pnl_c : color.new(color.black,65), text_size=size.small)

        table.merge_cells(dash,0,10,1,10)
        table.cell(dash,0,10,
                   "OR:" + str.tostring(i_or_min) + "m  Fib:" + str.tostring(i_fib_entry*100,"#") +
                   "%  " + str.tostring(i_target_r,"#.#") + "R  MACD:" + i_macd_cond,
                   text_color=color.new(color.white,50), bgcolor=color.new(color.black,75),
                   text_size=size.tiny, text_halign=text.align_center)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════

if entry_fired and brk_dir == "LONG"
    alert("Fib-MACD ORB: LONG entry at "  + str.tostring(close) + " on " + syminfo.ticker, alert.freq_once_per_bar_close)

if entry_fired and brk_dir == "SHORT"
    alert("Fib-MACD ORB: SHORT entry at " + str.tostring(close) + " on " + syminfo.ticker, alert.freq_once_per_bar_close)

if state[1] == "IN_TRADE" and state == "DONE" and is_exit_bar
    alert("Fib-MACD ORB: Force-closed at " + str.tostring(close) + " on " + syminfo.ticker + " (time exit)", alert.freq_once_per_bar_close)
